# Compiled Go sidecar binaries — `go build .` in mcp/<name>/ produces
# a binary named after the directory. One entry per app keeps the list
# explicit; gitignore globs can't match "file with same name as parent
# dir" cleanly, so we enumerate.
mcp/analytics/analytics
mcp/auth/auth
mcp/backup/backup
mcp/billing/billing
mcp/bills/bills
mcp/calendar/calendar
mcp/certs/certs
mcp/code/code
mcp/computer/computer
mcp/crm/crm
mcp/deploy/deploy
mcp/dlna/dlna
mcp/docs/docs
mcp/domains/domains
mcp/email-checker/email-checker
mcp/ffmpeg/ffmpeg
mcp/health/health
mcp/image-studio/image-studio
mcp/jobs/jobs
mcp/live-link/live-link
mcp/media/media
mcp/messaging/messaging
mcp/mqtt/mqtt
mcp/social/social
mcp/status/status
mcp/storage/storage
mcp/tables/tables
mcp/tapo/tapo
mcp/tasks/tasks
mcp/todo/todo
mcp/torrent/torrent
mcp/trading/trading

# Stray apps-root binary from accidental `go build` in the wrong dir.
/media

# Per-app runtime data dirs that get created when sidecars run locally.
mcp/jobs/data/
mcp/code/workspace/

# SQLite files left behind by local test runs.
*.db
*.db-shm
*.db-wal

# Test sidecar staging dir from sdk testkit.
_test_sidecar_bin

# Local-dev noise.
node_modules/
apteva-core.log

# Per-app local test credentials — .env.local files hold real secrets
# used by integration test scripts (backup → R2, etc.) and must never
# land in a repo.
mcp/*/scripts/.env.local
mcp/*/scripts/.env
