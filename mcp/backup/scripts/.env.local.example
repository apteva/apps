# Copy to .env.local and fill in your real R2 credentials.
# scripts/.env.local is in apps/.gitignore — never commit it.
#
# Where to get these:
#   - R2_ACCOUNT_ID:        dash.cloudflare.com → R2 → "Account ID"
#                           (32-char hex; same as the CF account id
#                           used by the cloudflare integration).
#   - R2_ACCESS_KEY_ID +
#     R2_SECRET_ACCESS_KEY: dash.cloudflare.com → R2 → Manage R2 API
#                           Tokens → Create API token. "Object Read &
#                           Write" is the minimum scope; restrict to
#                           the specific bucket if you can.
#   - R2_BUCKET:            existing R2 bucket name. The script does
#                           not create it; create it once in the
#                           dashboard before running.

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=backups
